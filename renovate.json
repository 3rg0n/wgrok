{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":semanticCommits"
  ],
  "schedule": ["before 6am on Monday"],
  "timezone": "America/Los_Angeles",
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "description": "Auto-merge patch updates (low risk)",
      "matchUpdateTypes": ["patch", "digest"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Group Python dependencies",
      "matchManagers": ["pip_requirements", "pip-compile", "pep621"],
      "matchFileNames": ["python/**"],
      "groupName": "python dependencies"
    },
    {
      "description": "Group Go dependencies",
      "matchManagers": ["gomod"],
      "matchFileNames": ["go/**"],
      "groupName": "go dependencies"
    },
    {
      "description": "Group TypeScript dependencies",
      "matchManagers": ["npm"],
      "matchFileNames": ["ts/**"],
      "groupName": "typescript dependencies"
    },
    {
      "description": "Group Rust dependencies",
      "matchManagers": ["cargo"],
      "matchFileNames": ["rust/**"],
      "groupName": "rust dependencies"
    },
    {
      "description": "Group GitHub Actions",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "webex-message-handler updated across all ecosystems together",
      "matchPackageNames": [
        "webex-message-handler",
        "github.com/3rg0n/webex-message-handler/go"
      ],
      "groupName": "webex-message-handler",
      "schedule": ["at any time"]
    },
    {
      "description": "Do not widen Python version ranges, bump minimum",
      "matchManagers": ["pep621"],
      "rangeStrategy": "bump"
    },
    {
      "description": "Major updates require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major"]
    }
  ],
  "ignorePaths": ["**/node_modules/**", "**/.venv/**"]
}
