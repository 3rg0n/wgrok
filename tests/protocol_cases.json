{
  "echo_prefix": "./echo:",

  "format_echo": [
    {"to": "worker", "from": "relay", "flags": "-", "payload": "hello", "expected": "./echo:worker:relay:-:hello"},
    {"to": "worker", "from": "relay", "flags": "-", "payload": "", "expected": "./echo:worker:relay:-:"},
    {"to": "slug", "from": "-", "flags": "-", "payload": "a:b:c", "expected": "./echo:slug:-:-:a:b:c"},
    {"to": "worker", "from": "relay", "flags": "z", "payload": "H4sI", "expected": "./echo:worker:relay:z:H4sI"},
    {"to": "worker", "from": "relay", "flags": "1/3", "payload": "chunk", "expected": "./echo:worker:relay:1/3:chunk"},
    {"to": "worker", "from": "relay", "flags": "z2/5", "payload": "data", "expected": "./echo:worker:relay:z2/5:data"},
    {"to": "worker", "from": "relay", "flags": "e", "payload": "encrypted", "expected": "./echo:worker:relay:e:encrypted"},
    {"to": "worker", "from": "relay", "flags": "ze", "payload": "both", "expected": "./echo:worker:relay:ze:both"}
  ],

  "parse_echo": {
    "valid": [
      {"input": "./echo:worker:relay:-:hello", "to": "worker", "from": "relay", "flags": "-", "payload": "hello"},
      {"input": "./echo:worker:relay:-:", "to": "worker", "from": "relay", "flags": "-", "payload": ""},
      {"input": "./echo:slug:-:-:a:b:c", "to": "slug", "from": "-", "flags": "-", "payload": "a:b:c"},
      {"input": "./echo:worker:relay:z:H4sI", "to": "worker", "from": "relay", "flags": "z", "payload": "H4sI"},
      {"input": "./echo:worker:relay:z2/5:data", "to": "worker", "from": "relay", "flags": "z2/5", "payload": "data"}
    ],
    "errors": [
      {"input": "plain text", "error_contains": "not an echo"},
      {"input": "./echo::relay:-:payload", "error_contains": "empty"}
    ]
  },

  "is_echo": [
    {"input": "./echo:worker:relay:-:payload", "expected": true},
    {"input": "worker:relay:-:payload", "expected": false},
    {"input": "", "expected": false}
  ],

  "format_response": [
    {"to": "worker", "from": "relay", "flags": "-", "payload": "hello", "expected": "worker:relay:-:hello"},
    {"to": "worker", "from": "relay", "flags": "-", "payload": "", "expected": "worker:relay:-:"},
    {"to": "slug", "from": "-", "flags": "z", "payload": "H4sI", "expected": "slug:-:z:H4sI"}
  ],

  "parse_response": {
    "valid": [
      {"input": "worker:relay:-:hello", "to": "worker", "from": "relay", "flags": "-", "payload": "hello"},
      {"input": "slug:-:-:a:b:c", "to": "slug", "from": "-", "flags": "-", "payload": "a:b:c"},
      {"input": "worker:relay:z:H4sI", "to": "worker", "from": "relay", "flags": "z", "payload": "H4sI"}
    ],
    "errors": [
      {"input": ":relay:-:payload", "error_contains": "empty"}
    ]
  },

  "parse_flags": [
    {"input": "-", "compressed": false, "encrypted": false, "chunk_seq": null, "chunk_total": null},
    {"input": "z", "compressed": true, "encrypted": false, "chunk_seq": null, "chunk_total": null},
    {"input": "e", "compressed": false, "encrypted": true, "chunk_seq": null, "chunk_total": null},
    {"input": "ze", "compressed": true, "encrypted": true, "chunk_seq": null, "chunk_total": null},
    {"input": "1/3", "compressed": false, "encrypted": false, "chunk_seq": 1, "chunk_total": 3},
    {"input": "z2/5", "compressed": true, "encrypted": false, "chunk_seq": 2, "chunk_total": 5},
    {"input": "e1/3", "compressed": false, "encrypted": true, "chunk_seq": 1, "chunk_total": 3},
    {"input": "ze2/5", "compressed": true, "encrypted": true, "chunk_seq": 2, "chunk_total": 5},
    {"input": "10/10", "compressed": false, "encrypted": false, "chunk_seq": 10, "chunk_total": 10}
  ],

  "format_flags": [
    {"compressed": false, "encrypted": false, "chunk_seq": null, "chunk_total": null, "expected": "-"},
    {"compressed": true, "encrypted": false, "chunk_seq": null, "chunk_total": null, "expected": "z"},
    {"compressed": false, "encrypted": true, "chunk_seq": null, "chunk_total": null, "expected": "e"},
    {"compressed": true, "encrypted": true, "chunk_seq": null, "chunk_total": null, "expected": "ze"},
    {"compressed": false, "encrypted": false, "chunk_seq": 1, "chunk_total": 3, "expected": "1/3"},
    {"compressed": true, "encrypted": false, "chunk_seq": 2, "chunk_total": 5, "expected": "z2/5"},
    {"compressed": false, "encrypted": true, "chunk_seq": 1, "chunk_total": 3, "expected": "e1/3"},
    {"compressed": true, "encrypted": true, "chunk_seq": 2, "chunk_total": 5, "expected": "ze2/5"}
  ],

  "is_pause": [
    {"input": "./pause", "expected": true},
    {"input": "./resume", "expected": false},
    {"input": "./echo:pause:from:-:payload", "expected": false},
    {"input": "pause", "expected": false},
    {"input": " ./pause ", "expected": true},
    {"input": "", "expected": false}
  ],

  "is_resume": [
    {"input": "./resume", "expected": true},
    {"input": "./pause", "expected": false},
    {"input": "./echo:resume:from:-:payload", "expected": false},
    {"input": "resume", "expected": false},
    {"input": " ./resume ", "expected": true},
    {"input": "", "expected": false}
  ],

  "roundtrips": {
    "echo": [
      {"to": "worker", "from": "relay", "flags": "-", "payload": "some data here"}
    ],
    "response": [
      {"to": "worker", "from": "relay", "flags": "-", "payload": "data"}
    ]
  }
}
