{
  "config": {
    "token": "fake-token",
    "target": "echobot@example.com",
    "slug": "testagent"
  },

  "cases": [
    {
      "name": "send_formats_and_sends",
      "payload": "hello world",
      "card": null,
      "expected_text": "./echo:testagent:hello world",
      "expected_target": "echobot@example.com",
      "expected_uses_card": false
    },
    {
      "name": "send_payload_with_colons",
      "payload": "a:b:c",
      "card": null,
      "expected_text": "./echo:testagent:a:b:c",
      "expected_target": "echobot@example.com",
      "expected_uses_card": false
    },
    {
      "name": "send_with_card",
      "payload": "hello",
      "card": {"type": "AdaptiveCard", "body": [{"type": "TextBlock", "text": "Hi"}]},
      "expected_text": "./echo:testagent:hello",
      "expected_target": "echobot@example.com",
      "expected_uses_card": true
    },
    {
      "name": "send_without_card_uses_send_message",
      "payload": "no card",
      "card": null,
      "expected_text": "./echo:testagent:no card",
      "expected_target": "echobot@example.com",
      "expected_uses_card": false
    }
  ]
}
