{
  "config": {
    "token": "fake-token",
    "target": "routerbot@example.com",
    "slug": "testagent",
    "from_slug": "testagent"
  },

  "cases": [
    {
      "name": "send_formats_and_sends",
      "payload": "hello world",
      "card": null,
      "compress": false,
      "expected_text": "./echo:testagent:testagent:-:hello world",
      "expected_target": "routerbot@example.com",
      "expected_uses_card": false
    },
    {
      "name": "send_payload_with_colons",
      "payload": "a:b:c",
      "card": null,
      "compress": false,
      "expected_text": "./echo:testagent:testagent:-:a:b:c",
      "expected_target": "routerbot@example.com",
      "expected_uses_card": false
    },
    {
      "name": "send_with_card",
      "payload": "hello",
      "card": {"type": "AdaptiveCard", "body": [{"type": "TextBlock", "text": "Hi"}]},
      "compress": false,
      "expected_text": "./echo:testagent:testagent:-:hello",
      "expected_target": "routerbot@example.com",
      "expected_uses_card": true
    },
    {
      "name": "send_without_card_uses_send_message",
      "payload": "no card",
      "card": null,
      "compress": false,
      "expected_text": "./echo:testagent:testagent:-:no card",
      "expected_target": "routerbot@example.com",
      "expected_uses_card": false
    }
  ]
}
