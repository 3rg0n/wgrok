# wgrok Rust configuration

# Webex API token (required for all components)
WGROK_TOKEN=your_webex_token_here

# Target email for the echo bot (required for sender)
WGROK_TARGET=echobot@example.com

# Slug for message routing (required for sender/receiver)
WGROK_SLUG=myagent

# Comma-separated allowlist of domains/emails (required for echo bot and receiver)
WGROK_DOMAINS=example.com,*@example.com

# Enable NDJSON debug logging to stderr (optional, default: false)
WGROK_DEBUG=false
